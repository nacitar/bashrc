#!/bin/bash
set -eu

# Avoid leaking an active venv into tool operations.
unset VIRTUAL_ENV

echo "uv: upgrading packages..."
if ! command -v uv >/dev/null 2>&1; then
    >&2 echo "WARNING: uv isn't installed; nothing to do."
    exit 0
fi

if uv tool upgrade --all; then
    exit 0
fi

>&2 echo "ERROR: uv upgrade failed."
exit 1
